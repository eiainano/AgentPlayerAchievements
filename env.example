# AGPA Environment Configuration
# Copy to .env and adjust, or set directly in your shell.

# Display language (en | zh)
# Default: en
AGPA_LANG=en

# Comma-separated list of enabled achievement categories
# Leave empty to enable all categories
# Example: onboarding,skill,tool_mastery
AGPA_ENABLED_CATEGORIES=

# Enable debug logging
# Default: false
AGPA_DEBUG=false

# Custom state directory for achievement progress and event log
# Default: ~/.agent-achievements
# AGPA_STATE_DIR=/path/to/custom/dir
